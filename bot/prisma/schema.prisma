generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model migrations {
  id        Int    @id @default(autoincrement())
  migration String @db.VarChar(255)
  batch     Int
}

model users {
  id         String     @id @db.Uuid
  name       String     @db.VarChar(255)
  email      String?    @unique(map: "users_email_unique") @db.VarChar(255)
  phone      String     @unique(map: "users_phone_unique") @db.VarChar(255)
  status     String     @default("guest") @db.VarChar(255)
  created_at DateTime?  @db.Timestamp(0)
  updated_at DateTime?  @db.Timestamp(0)
  accounts   accounts[]
  bookings   bookings[]
}

model accounts {
  id                   String    @id @db.Uuid
  user_id              String    @db.Uuid
  email                String    @unique(map: "accounts_email_unique") @db.VarChar(255)
  password_hash        String    @db.VarChar(255)
  password_reset_token String?   @db.VarChar(255)
  email_verified_at    DateTime? @db.Timestamp(0)
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
  users                users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "accounts_user_id_foreign")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                     String    @id @db.Uuid
  user_id                String    @db.Uuid
  trip_id                String    @db.Uuid
  seat_id                String    @db.Uuid
  payment_ref            String    @unique(map: "bookings_payment_ref_unique") @db.VarChar(255)
  payment_customer_id    String    @db.VarChar(255)
  payment_gateway        String    @default("paystack") @db.VarChar(255)
  virtual_account_number String    @db.VarChar(255)
  amount_paid            Decimal?  @db.Decimal(10, 2)
  payment_status         String    @db.VarChar(255)
  booked_at              DateTime? @db.Timestamp(0)
  expires_at             DateTime  @db.Timestamp(0)
  created_at             DateTime? @db.Timestamp(0)
  updated_at             DateTime? @db.Timestamp(0)
  seats                  seats     @relation(fields: [seat_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bookings_seat_id_foreign")
  trips                  trips     @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bookings_trip_id_foreign")
  users                  users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bookings_user_id_foreign")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model seats {
  id          String     @id @db.Uuid
  trip_id     String     @db.Uuid
  seat_number String     @db.VarChar(255)
  status      String     @db.VarChar(255)
  held_until  DateTime?  @db.Timestamp(0)
  created_at  DateTime?  @db.Timestamp(0)
  updated_at  DateTime?  @db.Timestamp(0)
  bookings    bookings[]
  trips       trips      @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "seats_trip_id_foreign")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model trips {
  id             String     @id @db.Uuid
  origin         String     @db.VarChar(255)
  destination    String     @db.VarChar(255)
  departure_time DateTime   @db.Timestamp(0)
  capacity       Int
  price          Decimal    @db.Decimal(10, 2)
  status         String     @db.VarChar(255)
  created_at     DateTime?  @db.Timestamp(0)
  updated_at     DateTime?  @db.Timestamp(0)
  bookings       bookings[]
  seats          seats[]
}
